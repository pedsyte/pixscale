# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# Runtime data (не храним пользовательские файлы в репо)
uploads/*
!uploads/.gitkeep
outputs/*
!outputs/.gitkeep

# AI модели (большие, качаются отдельным скриптом)
models/*.pb
!models/.gitkeep

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
